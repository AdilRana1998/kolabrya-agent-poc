# Copy this file to ".env" and fill in real values.
# The .env file is loaded by the Electron main process at startup.

# === Kolabrya backend ===
# Base URL for the inc-case API. All tool calls hit `${API_BASE_URL}/<endpoint>`.
API_BASE_URL=https://your-backend.example.com/api/inc-case

# Login endpoint (POST email/password -> { token }). Override if your auth lives elsewhere.
AUTH_LOGIN_URL=https://your-backend.example.com/api/auth/login

# Default caseType UUID used when the agent creates a case (per spec example).
DEFAULT_CASE_TYPE=61ca1224-ed9c-4d3f-8bc0-31b5fc8b203f

# === OpenAI ===
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# === Upload tuning ===
# How many files to upload to Azure in parallel.
UPLOAD_CONCURRENCY=4
# Max retry attempts per Azure PUT.
UPLOAD_MAX_RETRIES=3

# === Microsoft Outlook (Microsoft Graph) ===
# Azure AD app registration. See README.outlook.md for setup.
# Client ID of your Azure AD app registration (Application (client) ID).
MSGRAPH_CLIENT_ID=
# Tenant ID, or "common" for personal+work, "organizations" for work-only,
# or your single tenant's GUID for a locked-down deployment.
MSGRAPH_TENANT_ID=common
# Redirect URI registered in the AAD app (must be a "Mobile and desktop" platform
# entry). Loopback is recommended for desktop apps.
MSGRAPH_REDIRECT_URI=http://localhost:53682/auth/callback
# Comma-separated Graph scopes. Mail.ReadWrite covers read+move/flag.
MSGRAPH_SCOPES=offline_access,Mail.Read,Mail.ReadWrite,Mail.Send,User.Read

# === Inbox monitor ===
# How often to poll Microsoft Graph for new mail (seconds). 60 is a safe default.
OUTLOOK_POLL_SECONDS=60
# Where downloaded attachments land. Falls back to <userData>/inbox-records/.
OUTLOOK_DOWNLOAD_ROOT=
# How records are foldered: by_patient | by_case | by_doctor | flat
OUTLOOK_ORGANIZE_BY=by_patient
# When a reply matches a known request, auto-upload to the linked Kolabrya case.
OUTLOOK_AUTO_UPLOAD_ON_MATCH=true
